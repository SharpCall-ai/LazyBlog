# cp .env.example .env and fill in. Never commit .env.

# Generation. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# One signing secret per site: LAZYBLOG_SECRET_<SITENAME>, uppercased, dashes as
# underscores. sites/mysite/ -> LAZYBLOG_SECRET_MYSITE. Your receiver checks the
# X-LazyBlog-Signature header against this same value.
#
#   openssl rand -hex 32
LAZYBLOG_SECRET_MYSITE=
